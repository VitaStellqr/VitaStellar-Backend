# Application
NODE_ENV=development
APP_NAME=Stellar Uzima Backend
APP_PORT=3001
APP_VERSION=1.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=stellar_uzima_dev
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRATION=604800

# Stellar Blockchain
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FUNDING_SECRET=your_stellar_account_secret_key

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# External Services
EMAIL_SERVICE_API_KEY=your_email_service_key
SMS_GATEWAY_API_KEY=your_sms_gateway_key
