# ── Application ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────────
# Type: string | Required: yes | Default: none
# Hostname of the PostgreSQL database server
DATABASE_HOST=localhost

# Type: number | Required: no | Default: 5432 | Valid range: 1–65535
# Port number of the PostgreSQL database server
DATABASE_PORT=5432

# Type: string | Required: yes | Default: none
# PostgreSQL database username
DATABASE_USERNAME=postgres

# Type: string | Required: yes | Default: none
# PostgreSQL database password
DATABASE_PASSWORD=postgres

# Type: string | Required: yes | Default: none
# Name of the PostgreSQL database to connect to
DATABASE_NAME=uzima

# ── Redis ─────────────────────────────────────────────────────────────────────────
# Type: string (URI) | Required: yes | Default: none | Format: redis://host:port or rediss://host:port (TLS)
# Full Redis connection URL (overrides individual REDIS_HOST/PORT/TLS settings)
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ──────────────────────────────────────────────────────────
# Type: string | Required: yes | Default: none | Min length: 32 characters
# Secret key used to sign and verify JWT tokens. Must be at least 32 characters long.
# Example: $(openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Rate Limiting ────────────────────────────────────────────────────────────────
# Type: number | Required: no | Default: 60
# Time window in seconds for the rate limit throttle
RATE_LIMIT_TTL=60

# Type: number | Required: no | Default: 100
# Maximum number of requests allowed within the rate limit window
RATE_LIMIT_LIMIT=100

# ── Stellar Blockchain ──────────────────────────────────────────────────────────
# Type: string | Required: yes | Default: none | Valid values: testnet, mainnet
# Stellar network to use. Use 'testnet' for development and 'mainnet' for production.
STELLAR_NETWORK=testnet

# Type: string | Required: yes | Default: none
# Stellar secret key for the treasury account used to distribute XLM rewards.
# WARNING: Never commit this to version control. Use a secrets manager in production.
# Example: SBX...
STELLAR_TREASURY_SECRET_KEY=your-stellar-treasury-secret-key-here

# ── AWS S3 Storage (optional) ─────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
